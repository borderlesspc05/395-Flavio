PORT=3001
NODE_ENV=development

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://sprint.magnusmind.io,https://app.magnusmind.io,https://395-flavio2.netlify.app,https://395-flavio.netlify.app,https://melodic-cupcake-80e777.netlify.app

# Firebase Admin (JSON string or path via GOOGLE_APPLICATION_CREDENTIALS)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Uma linha com \n literais (copie só o campo private_key do JSON do Firebase):
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# Se aparecer DECODER unsupported: sem aspas curvas, uma linha, PEM completo; gere novo JSON se necessário.
FIREBASE_PRIVATE_KEY=

# IA — OpenAI direto (recomendado para desenvolvimento com chave sk-proj-...)
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# IA — OpenRouter (alternativa; usa vários modelos via proxy)
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://magnusmind.app
OPENROUTER_APP_NAME=Magnus Mind

# Web search (use one)
SERPER_API_KEY=
TAVILY_API_KEY=

# WhatsApp Cloud API (stub)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Timeouts (ms)
AXIOS_TIMEOUT=90000
CHAT_TIMEOUT=120000

# Stripe (checkout + assinaturas)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_ADVANCED=
STRIPE_PRICE_PREMIUM=
# URL do frontend (success/cancel do Checkout)
FRONTEND_URL=https://sprint.magnusmind.io
# Local: FRONTEND_URL=http://localhost:5173

# Recuperação de senha — rate limit (opcional)
# FIREBASE_WEB_API_KEY=   # mesma chave pública do Firebase (VITE_FIREBASE_API_KEY)
# PASSWORD_RESET_IP_MAX=8
# PASSWORD_RESET_IP_WINDOW_MIN=15
# PASSWORD_RESET_EMAIL_MAX=3
# PASSWORD_RESET_EMAIL_WINDOW_MIN=60

# Cron (Sprint Weekly Brief — segunda-feira via Render Cron Job)
# Gere um segredo longo e use o mesmo no job: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# E-mail transacional (equipe — resumo de desenvolvimento + Weekly Brief)
# Resend (recomendado): https://resend.com
RESEND_API_KEY=
# Sem EMAIL_FROM, o servidor usa onboarding@resend.dev (só envia ao e-mail da conta Resend).
# Produção: verifique um domínio em resend.com/domains e use, por exemplo:
# EMAIL_FROM=Magnus Mind <noreply@seudominio.com>
EMAIL_FROM=Magnus Mind <onboarding@resend.dev>
# Dev local com sandbox: redireciona todos os envios para o e-mail da sua conta Resend
# RESEND_TEST_RECIPIENT=seu-email@exemplo.com
# SMTP alternativo (opcional)
SMTP_HOST=

# Admin (emails separados por vírgula)
ADMIN_EMAILS=admin@gmail.com
# Opcional — script npm run seed:admin
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=123456

# RAG vetorial (Supabase pgvector + OpenAI embeddings)
RAG_ENABLED=false
RAG_TOP_K=5
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
